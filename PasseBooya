<style>
*{margin:0;padding:0;box-sizing:border-box}
body {background:#0f0f0f;color:white;font-family:'Segoe UI',Arial,sans-serif;text-align:center}
.header {background:linear-gradient(135deg,#a020f0,#ff006e);padding:30px 20px;margin-bottom:20px}
.header h1 {font-size:32px;margin-bottom:8px;text-shadow:0 2px 10px rgba(0,0,0,0.3)}
.header p {font-size:16px;opacity:0.9}
.container {padding:20px;max-width:600px;margin:0 auto}
.card {background:#1a1a1a;border:1px solid #2a2a2a;border-radius:16px;padding:25px;margin-bottom:20px;box-shadow:0 4px 20px rgba(160,32,240,0.1)}
.card h2 {color:#a020f0;margin-bottom:15px;font-size:24px}
.card .preco {color:#00ff88;font-size:36px;font-weight:bold;margin:10px 0}
.card .beneficios {text-align:left;margin:20px 0;color:#ccc}
.card .beneficios li {margin:8px 0;list-style:none}
.card .beneficios li:before {content:"✓ ";color:#00ff88;font-weight:bold;margin-right:8px}
input {display:block;margin:12px auto;padding:14px;width:100%;border-radius:10px;border:1px solid #333;background:#0f0f0f;color:white;font-size:16px;transition:0.3s}
input:focus {outline:none;border-color:#a020f0;box-shadow:0 0 0 3px rgba(160,32,240,0.1)}
input::placeholder {color:#666}
.input-group {position:relative}
.status-cpf {position:absolute;right:15px;top:50%;transform:translateY(-50%);font-size:12px;font-weight:bold}
.valido {color:#00ff88}
.invalido {color:#ff4444}
button {background:linear-gradient(135deg,#a020f0,#ff006e);border:none;padding:16px 30px;color:white;font-size:18px;font-weight:bold;border-radius:12px;cursor:pointer;width:100%;margin-top:15px;transition:0.3s;text-transform:uppercase}
button:hover {transform:translateY(-2px);box-shadow:0 8px 25px rgba(160,32,240,0.4)}
button:disabled {background:#333;cursor:not-allowed;transform:none;box-shadow:none}
.social {display:flex;justify-content:center;gap:12px;margin:25px 0}
.social a {display:flex;align-items:center;gap:8px;text-decoration:none;color:white;background:#1a1a1a;padding:12px 20px;border-radius:10px;font-size:15px;border:1px solid #333;transition:0.3s}
.social a:hover {background:#2a2a2a;border-color:#a020f0;transform:translateY(-2px)}
.social img {width:20px;height:20px}
.qr {margin-top:25px;background:#1a1a1a;padding:20px;border-radius:16px;border:1px solid #2a2a2a}
.qr h3 {color:#00ff88;margin-bottom:15px}
.qr img {border-radius:12px;background:white;padding:12px;margin:10px 0}
.qr p {color:#ccc;font-size:14px;line-height:1.6}
.pix-copia-cola {margin-top:20px;text-align:left}
.pix-copia-cola label {font-size:14px;font-weight:bold;color:#a020f0;display:block;margin-bottom:8px}
.pix-codigo {background:#0f0f0f;border:1px solid #333;border-radius:10px;padding:12px;font-size:11px;word-break:break-all;color:#ccc;margin-bottom:12px}
.btn-copiar {background:#00b050;border:none;padding:12px 20px;color:white;font-size:15px;border-radius:10px;cursor:pointer;width:100%;font-weight:bold}
.btn-copiar:hover {background:#009640}
.footer {margin-top:40px;padding:20px;color:#666;font-size:13px}
.erro-msg {color:#ff4444;font-size:13px;text-align:left;margin:-8px auto 10px auto;display:none}
</style>
</head>
